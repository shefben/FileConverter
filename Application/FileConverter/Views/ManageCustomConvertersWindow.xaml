<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:project="clr-namespace:FileConverter.Properties"
        xmlns:views="clr-namespace:FileConverter.Views"
        x:Class="FileConverter.Views.ManageCustomConvertersWindow"
        Title="Custom Converters" Height="450" Width="600" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/ConversionPresetTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel Margin="10">
        <Button DockPanel.Dock="Top" HorizontalAlignment="Right" Content="{x:Static project:Resources.AddCustomConverter}" Command="{Binding AddCommand}" Width="140" Margin="0,0,0,5"/>
        <TabControl>
            <TabItem Header="Converters">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListBox ItemsSource="{Binding Converters}" SelectedItem="{Binding Selected}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="16" Height="16" Margin="0,0,5,0" Source="{Binding IconAbsolutePath}"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Edit" Width="70" Margin="5" Command="{Binding EditCommand}"/>
                        <Button Content="Remove" Width="70" Margin="5" Command="{Binding RemoveCommand}"/>
                        <Button Content="Import" Width="70" Margin="5" Command="{Binding ImportCommand}"/>
                        <Button Content="Export" Width="70" Margin="5" Command="{Binding ExportCommand}"/>
                        <Button Content="Close" Width="70" Margin="5" IsCancel="True"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="{x:Static project:Resources.CustomPresets}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <ListBox ItemsSource="{Binding CustomPresets}" SelectedItem="{Binding SelectedCustomPreset}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ShortName}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <ContentControl Grid.Column="1" Content="{Binding SelectedCustomPreset}" ContentTemplate="{StaticResource CustomConverterSettingsDataTemplate}" Margin="10,0,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
